<Window x:Class="IsDccSharp.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IsDccSharp Viewer"
        Icon="/IsDccSharp.Viewer;component/Assets/IsDccSharp.ico"
        Width="1180"
        Height="760"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F6"
        FontFamily="Segoe UI"
        FontSize="13">
  <Window.Resources>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LineBrush" Color="#CBD4DF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#E6EEFF" />
    <SolidColorBrush x:Key="HoverBorderBrush" Color="#7EA2F8" />
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#EEF1F5" />
    <SolidColorBrush x:Key="DisabledBorderBrush" Color="#D6DEE8" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#8A94A3" />

    <Style x:Key="CommandButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1F2937" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource HoverBorderBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                <Setter Property="Cursor" Value="Arrow" />
                <Setter Property="Opacity" Value="0.62" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DisabledBackgroundBrush}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource DisabledBorderBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryCommandButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource CommandButtonStyle}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="MinWidth" Value="106" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource HoverBorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                <Setter Property="Cursor" Value="Arrow" />
                <Setter Property="Opacity" Value="0.62" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DisabledBackgroundBrush}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource DisabledBorderBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolIconStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OptionCheckBoxStyle" TargetType="{x:Type CheckBox}">
      <Setter Property="Width" Value="168" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type CheckBox}">
            <Border x:Name="OptionBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="24" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="CheckBoxMark"
                        Width="18"
                        Height="18"
                        BorderBrush="#AAB6C5"
                        BorderThickness="1"
                        Background="#FFFFFF"
                        CornerRadius="3"
                        VerticalAlignment="Center">
                  <TextBlock x:Name="CheckGlyph"
                             Text="&#xE73E;"
                             FontFamily="Segoe MDL2 Assets"
                             FontSize="11"
                             Foreground="#FFFFFF"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Visibility="Collapsed" />
                </Border>

                <ContentPresenter Grid.Column="1"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OptionBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{StaticResource HoverBorderBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="#BFD0FF" />
                <Setter TargetName="CheckBoxMark" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="CheckBoxMark" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
                <Setter Property="Opacity" Value="0.62" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,4,8,4">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource CommandButtonStyle}"
                  Command="{Binding OpenCommand}"
                  ToolTip="Open INX file">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE8E5;" />
              <TextBlock Text="Open" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Style="{StaticResource PrimaryCommandButtonStyle}"
                  Command="{Binding DecodeCommand}"
                  ToolTip="Decode selected file">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE768;" />
              <TextBlock Text="Decode" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CommandButtonStyle}"
                  Command="{Binding SaveCommand}"
                  ToolTip="Save decoded output">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE74E;" />
              <TextBlock Text="Save" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CommandButtonStyle}"
                  Command="{Binding CopyCommand}"
                  ToolTip="Copy decoded output">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE8C8;" />
              <TextBlock Text="Copy" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CommandButtonStyle}"
                  Command="{Binding AboutCommand}"
                  ToolTip="About IsDccSharp">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE946;" />
              <TextBlock Text="About" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <TextBox Grid.Column="1"
                 Height="36"
                 Margin="8,0,0,0"
                 Padding="10,6"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 BorderBrush="{StaticResource LineBrush}"
                 Background="#F8FAFC"
                 Foreground="#1F2937"
                 Text="{Binding FilePath, Mode=OneWay}" />

        <ItemsControl Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,12,0,0"
                      IsEnabled="{Binding OptionsEnabled, Mode=OneWay}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                    IsChecked="{Binding IncludeStringUserVariables, Mode=TwoWay}">
            <StackPanel>
              <TextBlock Text="String variables" FontWeight="SemiBold" />
              <TextBlock Text="User string vars"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </CheckBox>

          <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                    IsChecked="{Binding IncludeNumberUserVariables, Mode=TwoWay}">
            <StackPanel>
              <TextBlock Text="Number variables" FontWeight="SemiBold" />
              <TextBlock Text="User number vars"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </CheckBox>

          <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                    IsChecked="{Binding IncludeDataTypes, Mode=TwoWay}">
            <StackPanel>
              <TextBlock Text="Data types" FontWeight="SemiBold" />
              <TextBlock Text="Typedef blocks"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </CheckBox>

          <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                    IsChecked="{Binding IncludeFunctionPrototypes, Mode=TwoWay}">
            <StackPanel>
              <TextBlock Text="Prototypes" FontWeight="SemiBold" />
              <TextBlock Text="Function declarations"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </CheckBox>

          <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                    IsChecked="{Binding IncludeFunctionDefinitions, Mode=TwoWay}">
            <StackPanel>
              <TextBlock Text="Definitions" FontWeight="SemiBold" />
              <TextBlock Text="Function bodies"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </CheckBox>
        </ItemsControl>
      </Grid>
    </Border>

    <StatusBar DockPanel.Dock="Bottom"
               Background="{StaticResource SurfaceBrush}"
               BorderBrush="{StaticResource LineBrush}"
               BorderThickness="0,1,0,0">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusText, Mode=OneWay}" />
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="14">
      <Border Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1">
        <TextBox AcceptsReturn="True"
                 AcceptsTab="True"
                 FontFamily="Consolas"
                 FontSize="13"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 BorderThickness="0"
                 Background="{StaticResource SurfaceBrush}"
                 Foreground="#111827"
                 Padding="12"
                 Text="{Binding OutputText, Mode=OneWay}" />
      </Border>
    </Grid>
  </DockPanel>
</Window>
